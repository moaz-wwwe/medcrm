# Rename this file to ".env" and fill in real values before running the server.

# Secret used to sign JWT access tokens. Generate a strong random string for production,
# e.g. `python -c "import secrets; print(secrets.token_hex(32))"`
SECRET_KEY=change-this-to-a-long-random-secret

# Access token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Google Gemini API key, used by the /api/manager-chat endpoint.
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_google_ai_studio_api_key_here"
GEMINI_MODEL=gemini-2.5-flash

# Telegram Bot settings for admin notifications
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"
TELEGRAM_CHAT_ID="your_telegram_chat_id_here"

# Neon Database URL
DATABASE_URL="postgresql://user:password@endpoint.neon.tech/dbname?sslmode=require"
