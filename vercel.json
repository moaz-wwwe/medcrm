{
  "version": 2,
  "builds": [
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/auth/(.*)",
      "dest": "/backend/main.py"
    },
    {
      "src": "/leads/(.*)",
      "dest": "/backend/main.py"
    },
    {
      "src": "/call-logs/(.*)",
      "dest": "/backend/main.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "/backend/main.py"
    },
    {
      "src": "/docs/?",
      "dest": "/backend/main.py"
    },
    {
      "src": "/openapi.json",
      "dest": "/backend/main.py"
    },
    {
      "src": "/",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
